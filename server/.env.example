# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB (Phase 2 — get from MongoDB Atlas)
MONGODB_URI=mongodb+srv://your_user:your_password@cluster.mongodb.net/internjetco

# JWT (Phase 2)
JWT_SECRET=your_jwt_secret_here_change_this
JWT_EXPIRE=7d

# Cloudinary (Phase 3 — get from cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Resend (Phase 3 — get from resend.com)
RESEND_API_KEY=your_resend_api_key

# Google OAuth (Phase 6 — get from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ZEGOCLOUD (Phase 4 — get from zegocloud.com)
ZEGOCLOUD_APP_ID=your_app_id
ZEGOCLOUD_SERVER_SECRET=your_server_secret

# Google Gemini AI (Phase 5 — get from aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key
